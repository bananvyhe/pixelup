<section class="grid two">
  <section class="panel">
    <h1>Платёж <%= @payment_transaction.label %></h1>
    <div class="stack muted">
      <div><strong>Сумма запроса:</strong> <%= rubles(@payment_transaction.requested_amount_cents) %></div>
      <div><strong>Статус:</strong> <%= @payment_transaction.status %></div>
      <% if @payment_transaction.paid? %>
        <div><strong>Зачислено:</strong> <%= rubles(@payment_transaction.credited_amount_cents) %></div>
      <% end %>
    </div>
  </section>

  <section class="panel">
    <h2>Оплата через YooMoney</h2>
    <% if @payment_form.configured? %>
      <p class="muted">
        Можно оплатить с кошелька YooMoney или картой банка. Внутренний баланс будет
        увеличен на полную сумму платежа.
      </p>

      <div class="stack">
        <%= form_with url: @payment_form.endpoint, method: :post, local: true, authenticity_token: false do |form| %>
          <% @payment_form.card_fields.each do |key, value| %>
            <%= hidden_field_tag key, value %>
          <% end %>
          <%= form.submit "Оплатить банковской картой" %>
        <% end %>

        <%= form_with url: @payment_form.endpoint, method: :post, local: true, authenticity_token: false do |form| %>
          <% @payment_form.wallet_fields.each do |key, value| %>
            <%= hidden_field_tag key, value %>
          <% end %>
          <%= form.submit "Оплатить через кошелёк YooMoney", class: "button secondary" %>
        <% end %>
      </div>
    <% else %>
      <p class="muted">
        Реквизиты YooMoney ещё не добавлены. После передачи кошелька и секретов форма начнёт работать без доработки кода.
      </p>
    <% end %>
  </section>
</section>
