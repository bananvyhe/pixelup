<section class="panel">
  <div class="topbar" style="margin-bottom: 16px;">
    <h1>Месячные тарифы</h1>
    <%= link_to "Новый тариф", new_admin_tariff_path, class: "button" %>
  </div>

  <table>
    <thead>
      <tr>
        <th>Название</th>
        <th>В месяц</th>
        <th>Списание в час</th>
        <th>Дней</th>
        <th>Статус</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @tariffs.each do |tariff| %>
        <tr>
          <td><%= tariff.name %></td>
          <td><%= rubles(tariff.monthly_price_cents) %></td>
          <td><%= rubles(tariff.hourly_rate_cents) %></td>
          <td><%= tariff.billing_period_days %></td>
          <td><%= tariff.active? ? "активен" : "скрыт" %></td>
          <td><%= link_to "Изменить", edit_admin_tariff_path(tariff), class: "button secondary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
